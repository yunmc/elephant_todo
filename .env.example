# 服务端环境变量配置（Nuxt runtimeConfig 自动读取）

# MySQL 数据库
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=elephant_todo

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Gemini LLM
GEMINI_API_KEY=your-gemini-api-key
GEMINI_BASE_URL=https://go.sbgpt.site/v1
GEMINI_MODEL=gemini-2.5-pro

# DeepSeek LLM (备用)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://llmapi.blsc.cn/v1
DEEPSEEK_MODEL=DeepSeek-V3.2

# 邮件服务（SMTP）
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=Elephant Todo <your-email@example.com>

# 密码重置
RESET_PASSWORD_URL=http://localhost:3001/reset-password
RESET_TOKEN_EXPIRES_IN=3600000

